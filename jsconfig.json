{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler", // <--- THIS IS THE KEY FOR 2026
    "jsx": "react-native",
    "checkJs": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./",
    "paths": {
      "react-native": ["./node_modules/react-native"],
      "*": ["node_modules/*"]
    }
  },
  "exclude": ["node_modules", "android", "ios"]
}
